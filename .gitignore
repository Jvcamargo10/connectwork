.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ──────────────────────────────────────────
#  Sistema operacional
# ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ──────────────────────────────────────────
#  Editores
# ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ──────────────────────────────────────────
